# ============================================================
# Winspacetime API Server - 生产环境配置模板
# ⚠️ 请将此文件重命名为 .env 并填入真实凭证
# ============================================================

# --- 基础鉴权 ---
JWT_USER_SECRET=自行生成长随机字符串
JWT_ADMIN_SECRET=自行生成长随机字符串
ADMIN_INIT_USERNAME=superadmin

# --- 阿里云 OSS 配置 (用于文件存储) ---
ALIBABA_CLOUD_ACCESS_KEY_ID=你的AccessKeyID
ALIBABA_CLOUD_ACCESS_KEY_SECRET=你的AccessKeySecret
OSS_REGION=oss-cn-hangzhou
OSS_BUCKET=你的Bucket名

# --- 阿里云 FC 配置 (用于 AI 计算) ---
# Endpoint 格式: <AccountID>.<Region>.fc.aliyuncs.com
FC_ENDPOINT=你的FC终端地址

# --- 业务回调配置 ---
# 云函数处理完后，需要访问该地址通知 API Server 更新状态
# 在生产环境下，这应该是你的公网域名，例如: https://api.yourdomain.com/api/webhook/fc
API_CALLBACK_URL=http://your-server-ip:3000/api/webhook/fc

# --- 外部 VLM API (可选) ---
VLM_BASE_URL=https://api.openai.com/v1
VLM_API_KEY=sk-xxxx
VLM_MODEL=gpt-4o
